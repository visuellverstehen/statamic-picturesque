{
    "name": "visuellverstehen/statamic-picturesque",
    "description": "A Statamic tag for building HTML-only responsive images.",
    "keywords": [ "statamic", "addon", "responsive", "image", "picture", "glide", "v5", "v6" ],
    "license": "MIT",
    "type": "statamic-addon",
    "autoload": {
        "psr-4": {
            "VV\\Picturesque\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "visuellverstehen"
        }
    ],
    "support": {
        "email": "hello@visuellverstehen.de"
    },
    "extra": {
        "statamic": {
            "name": "Statamic Picturesque",
            "description": "A Statamic tag for building HTML-only responsive images."
        },
        "laravel": {
            "providers": [
                "VV\\Picturesque\\ServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.3",
        "statamic/cms": "^5.0 || ^6.0"
    },
    "config": {
        "prefer-stable": true,
        "allow-plugins": {
            "pixelfear/composer-dist-plugin": true,
            "pestphp/pest-plugin": true
        }
    },
    "require-dev": {
        "pestphp/pest": "^4.1",
        "laravel/pint": "^1.25",
        "orchestra/testbench": "^9.0 || ^10.0"
    }
}
